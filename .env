# Entorno por defecto (no secreto). Los overrides locales van en .env.local.
APP_ENV=dev
APP_DEBUG=1
APP_SECRET=dev_secret_change_me

# La base de datos vive en el servicio "database" del docker-compose.
DATABASE_URL="mysql://siroko:siroko@database:3306/siroko?serverVersion=8.0&charset=utf8mb4"

# Moneda del catálogo (single-currency, D-002).
CATALOG_CURRENCY=EUR

# Pasarela fake: 1 para forzar el rechazo del pago (probar flujo FAILED).
PAYMENT_ALWAYS_FAILS=0
